# 1. Setup Backend
cd backend
cp .env.example .env
npm install

# 2. Setup Web
cd ../web
cp .env.example .env
npm install

# 3. Setup Mobile (Optional)
cd ../mobile
flutter pub get

# 4. Run in separate terminals:
# Terminal 1: Backend
cd backend && npm run dev

# Terminal 2: Web
cd web && npm run dev

# Terminal 3: Mobile (Optional)
cd mobile && flutter run
