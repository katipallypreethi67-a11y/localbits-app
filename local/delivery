          address: '123 Street, Hyderabad'
        },
        delivery_location: {
          latitude: 17.3900,
          longitude: 78.4900,
          address: '456 Avenue, Hyderabad'
        },
        distance: 2.5,
        estimated_time: 15,
        delivery_fee: 40,
        items_count: 3,
        customer_phone: '+91 9876543210',
        order_value: 745
      },
      {
        id: 'order_2',
        order_number: 'ORD-001235',
        restaurant_name: 'Pizza Corner',
        restaurant_location: {
          latitude: 17.3700,
          longitude: 78.4750,
          address: '789 Road, Hyderabad'
        },
        delivery_location: {
          latitude: 17.3800,
          longitude: 78.4800,
          address: '321 Lane, Hyderabad'
        },
        distance: 3.2,
        estimated_time: 18,
