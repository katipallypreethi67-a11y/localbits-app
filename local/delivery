        items_count: 2,
        customer_phone: '+91 9876543211',
        order_value: 899
      }
    ],
    total_orders: 2
  });
});

// Accept order
router.post('/:orderId/accept', authMiddleware, (req, res) => {
  res.status(200).json({ 
    success: true,
    message: 'Order accepted successfully',
    order_id: req.params.orderId,
    accepted_at: new Date(),
    delivery_partner_id: req.user.id
  });
});

// Reject order
router.post('/:orderId/reject', authMiddleware, (req, res) => {
  res.status(200).json({ 
    success: true,
    message: 'Order rejected',
    order_id: req.params.orderId,
    reason: req.body.reason || 'Not available'
  });
});

// Update delivery status
router.patch('/:orderId/status', authMiddleware, (req, res) => {
  const { status } = req.body;
  
  res.status(200).json({ 
    success: true,
    message: 'Delivery status updated',
    order_id: req.params.orderId,
    status: status,
    updated_at: new Date()
  });
});

// Update location
router.patch('/:orderId/location', authMiddleware, (req, res) => {
  const { latitude, longitude } = req.body;
  
  res.status(200).json({ 
    success: true,
    message: 'Location updated',
    order_id: req.params.orderId,
    location: {
      latitude,
      longitude
    },
    updated_at: new Date()
  });
});

// Get delivery earnings
router.get('/earnings/summary', authMiddleware, (req, res) => {
  res.status(200).json({ 
    success: true,
    message: 'Delivery earnings summary',
    delivery_partner_id: req.user.id,
    earnings: {
      today: 450,
      this_week: 2150,
      this_month: 8900,
      total: 45600,
      total_deliveries: 456,
      rating: 4.8
    }
  });
});

module.exports = router;
