// Get payment history
router.get('/history', authMiddleware, (req, res) => {
  const { page = 1, limit = 10 } = req.query;
  
  res.status(200).json({ 
    success: true,
    message: 'Payment history retrieved',
    payments: [
      {
        id: 'pay_1',
        order_id: 'order_1',
        amount: 745,
        currency: 'INR',
        status: 'completed',
        method: 'card',
        created_at: '2024-01-10T10:30:00Z'
      },
      {
        id: 'pay_2',
        order_id: 'order_2',
        amount: 899,
        currency: 'INR',
        status: 'completed',
        method: 'upi',
        created_at: '2024-01-09T18:45:00Z'
      }
    ],
    page: parseInt(page),
    limit: parseInt(limit),
