});

// Refund payment
router.post('/refund', authMiddleware, (req, res) => {
  const { payment_id, amount, reason } = req.body;
  
  res.status(200).json({ 
    success: true,
    message: 'Refund initiated',
    refund: {
      id: 'refund_' + Date.now(),
      payment_id: payment_id,
      amount: amount,
      reason: reason,
      status: 'pending',
      created_at: new Date()
    }
  });
});

module.exports = router;
